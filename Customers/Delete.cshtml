@page "{id:int}"
@model CrmLite.Pages.Customers.DeleteModel
@{ ViewData["Title"] = "删除客户"; }

<nav aria-label="breadcrumb"><ol class="breadcrumb">
    <li class="breadcrumb-item"><a asp-page="Index">客户管理</a></li>
    <li class="breadcrumb-item active">删除确认</li>
</ol></nav>

<h4 class="mb-4"><i class="bi bi-exclamation-triangle text-danger"></i> 确认删除</h4>

<div class="card border-danger"><div class="card-body">
    <h5 class="card-title">@Model.Customer.Name</h5>
    <table class="table table-sm table-borderless w-auto">
        <tr><td class="text-muted">客户编号：</td><td><code>@Model.Customer.Code</code></td></tr>
        <tr><td class="text-muted">行业：</td><td>@(Model.Customer.Industry ?? "-")</td></tr>
        <tr><td class="text-muted">地区：</td><td>@(Model.Customer.Region ?? "-")</td></tr>
        <tr><td class="text-muted">创建时间：</td><td>@Model.Customer.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td></tr>
    </table>

    @if (Model.HasContracts)
    {
        <div class="alert alert-warning mt-3">
            <i class="bi bi-exclamation-circle"></i> 该客户存在关联合同，<strong>无法删除</strong>。请先处理关联合约。
        </div>
    }
</div></div>

<form method="post" class="mt-3">
    @if (!Model.HasContracts)
    {
        <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> 确认删除</button>
    }
    <a asp-page="Index" class="btn btn-secondary">返回列表</a>
</form>
