@page
@model CrmLite.Pages.Customers.CreateModel
@{ ViewData["Title"] = "新增客户"; }

<nav aria-label="breadcrumb"><ol class="breadcrumb">
    <li class="breadcrumb-item"><a asp-page="Index">客户管理</a></li>
    <li class="breadcrumb-item active">新增客户</li>
</ol></nav>

<h4 class="mb-4"><i class="bi bi-plus-circle"></i> 新增客户</h4>

<div class="row"><div class="col-md-8">
<form method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="row g-3">
        <div class="col-md-6"><label asp-for="Customer.Name" class="form-label required"></label>
            <input asp-for="Customer.Name" class="form-control" placeholder="请输入客户名称" />
            <span asp-validation-for="Customer.Name" class="text-danger"></span></div>

        <div class="col-md-6"><label asp-for="Customer.Level" class="form-label"></label>
            <select asp-for="Customer.Level" asp-items="Model.LevelList" class="form-select"></select></div>

        <div class="col-md-6"><label asp-for="Customer.Industry" class="form-label"></label>
            <input asp-for="Customer.Industry" class="form-control" placeholder="如：制造业" /></div>

        <div class="col-md-6"><label asp-for="Customer.Scale" class="form-label"></label>
            <select asp-for="Customer.Scale" class="form-select">
                <option value="">请选择</option><option>小微企业</option><option>中型企业</option><option>大型企业</option>
            </select></div>

        <div class="col-md-6"><label asp-for="Customer.Region" class="form-label"></label>
            <select asp-for="Customer.Region" class="form-select">
                <option value="">请选择</option><option>华东</option><option>华南</option><option>华北</option><option>华中</option><option>西南</option><option>西北</option><option>东北</option>
            </select></div>

        <div class="col-md-6"><label asp-for="Customer.Phone" class="form-label"></label>
            <input asp-for="Customer.Phone" class="form-control" placeholder="如：0512-88888888" /></div>

        <div class="col-12"><label asp-for="Customer.Address" class="form-label"></label>
            <input asp-for="Customer.Address" class="form-control" placeholder="详细地址" /></div>

        <div class="col-md-6"><label asp-for="Customer.PostalCode" class="form-label"></label>
            <input asp-for="Customer.PostalCode" class="form-control" placeholder="邮政编码" /></div>

        <div class="col-md-6"><label asp-for="Customer.Website" class="form-label"></label>
            <input asp-for="Customer.Website" class="form-control" placeholder="https://" /></div>

        <div class="col-12"><label asp-for="Customer.Remark" class="form-label"></label>
            <textarea asp-for="Customer.Remark" class="form-control" rows="3" placeholder="备注信息"></textarea></div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> 保存</button>
        <a asp-page="Index" class="btn btn-secondary">取消</a>
    </div>
</form>
</div></div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
<style>.required::after { content: " *"; color: #dc3545; }</style>
