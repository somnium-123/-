<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — CRM Lite 企业客户与合同管理系统</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        :root { --primary: #0d6efd; --sidebar-width: 240px; }
        body { font-family: "Microsoft YaHei", "Segoe UI", sans-serif; background: #f5f6fa; min-height: 100vh; }
        .navbar-brand { font-weight: 700; letter-spacing: 1px; }
        .sidebar { position: fixed; top: 56px; left: 0; width: var(--sidebar-width); height: calc(100vh - 56px);
                   background: #2c3e50; color: #ecf0f1; overflow-y: auto; z-index: 100; transition: transform 0.3s; }
        .sidebar .nav-link { color: #bdc3c7; padding: 12px 20px; border-left: 3px solid transparent; transition: all 0.2s; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background: rgba(255,255,255,0.08); border-left-color: var(--primary); }
        .sidebar .nav-link i { margin-right: 8px; width: 20px; text-align: center; }
        .main-content { margin-left: var(--sidebar-width); padding: 20px 30px; min-height: calc(100vh - 56px); }
        .footer { margin-left: var(--sidebar-width); padding: 12px 30px; background: #fff; border-top: 1px solid #dee2e6;
                  font-size: 0.85rem; color: #6c757d; text-align: center; }
        .required::after { content: " *"; color: #dc3545; font-weight: bold; }
        .btn-sm i { font-size: 0.85rem; }
        @@media (max-width: 991.98px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.show { transform: translateX(0); }
            .main-content, .footer { margin-left: 0; }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- 顶部导航栏 -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container-fluid">
            <button class="navbar-toggler me-2 d-lg-none" type="button" onclick="document.querySelector('.sidebar').classList.toggle('show')">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a class="navbar-brand" href="/"><i class="bi bi-building"></i> CRM Lite</a>
            <span class="navbar-text d-none d-md-inline">企业客户与合同管理系统</span>
            <span class="navbar-text ms-auto"><i class="bi bi-calendar3"></i> @DateTime.Now.ToString("yyyy年MM月dd日")</span>
        </div>
    </nav>

    <!-- 侧边栏导航 -->
    <aside class="sidebar">
        <div class="p-3"><small class="text-secondary text-uppercase">功能菜单</small></div>
        <nav class="nav flex-column">
            <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Customers") ? "active" : "")"
               href="/Customers"><i class="bi bi-building"></i> 客户管理</a>
            <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Contacts") ? "active" : "")"
               href="/Contacts"><i class="bi bi-person-lines-fill"></i> 联系人管理</a>
            <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Contracts") ? "active" : "")"
               href="/Contracts"><i class="bi bi-file-earmark-text"></i> 合同管理</a>
        </nav>
        <hr class="border-secondary mx-3 my-2">
        <div class="p-3"><small class="text-secondary text-uppercase">关于</small></div>
        <div class="px-3 pb-3">
            <small class="text-muted">
                ASP.NET Core 7 + EF Core<br>
                Code First + DDD<br>
                信管2901-01组
            </small>
        </div>
    </aside>

    <!-- 主内容区 -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- 页脚 -->
    <footer class="footer">
        © 2026 南京工业大学 计算机学院 — 信管2901-01组 | 刘子涵 · 黄陈熙 · 关张旭 · 杨焱熙 | ASP.NET Core 网站开发课程设计
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
