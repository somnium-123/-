@page "{id:int}"
@model CrmLite.Pages.Contracts.DeleteModel
@{ ViewData["Title"] = "删除合同"; }

<nav aria-label="breadcrumb"><ol class="breadcrumb">
    <li class="breadcrumb-item"><a asp-page="Index">合同管理</a></li>
    <li class="breadcrumb-item active">删除确认</li>
</ol></nav>

<h4 class="mb-4"><i class="bi bi-exclamation-triangle text-danger"></i> 确认删除合同</h4>

<div class="card border-danger"><div class="card-body">
    <h5>@Model.Contract.Name</h5>
    <table class="table table-sm table-borderless w-auto mt-3">
        <tr><td class="text-muted">合同编号：</td><td><code>@Model.Contract.ContractCode</code></td></tr>
        <tr><td class="text-muted">关联客户：</td><td>@Model.Contract.Customer?.Name</td></tr>
        <tr><td class="text-muted">合同金额：</td><td><strong>¥@Model.Contract.Amount.ToString("N2")</strong></td></tr>
        <tr><td class="text-muted">签订日期：</td><td>@Model.Contract.SignedDate.ToString("yyyy-MM-dd")</td></tr>
        <tr><td class="text-muted">合同状态：</td><td>
            @(Model.Contract.Status == CrmLite.Models.ContractStatus.InProgress ? "执行中" :
              Model.Contract.Status == CrmLite.Models.ContractStatus.Completed ? "已完成" : "已终止")</td></tr>
    </table>
    <p class="text-muted mt-3">删除后不影响关联的客户和联系人数据。</p>
</div></div>

<form method="post" class="mt-3">
    <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> 确认删除</button>
    <a asp-page="Index" class="btn btn-secondary">返回列表</a>
</form>
