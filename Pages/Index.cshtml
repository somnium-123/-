@page
@model CrmLite.Pages.IndexModel
@{ ViewData["Title"] = "首页"; }

<div class="mb-4">
    <h3><i class="bi bi-speedometer2"></i> 系统仪表盘</h3>
    <p class="text-muted">欢迎使用企业客户与合同管理系统（CRM Lite）</p>
</div>

<div class="row g-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-primary text-primary h-100"><div class="card-body text-center">
            <i class="bi bi-building" style="font-size:3rem"></i>
            <h2 class="mt-2">@Model.CustomerCount</h2><p class="text-muted mb-0">客户总数</p>
        </div></div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-success text-success h-100"><div class="card-body text-center">
            <i class="bi bi-person-lines-fill" style="font-size:3rem"></i>
            <h2 class="mt-2">@Model.ContactCount</h2><p class="text-muted mb-0">联系人总数</p>
        </div></div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-warning text-warning h-100"><div class="card-body text-center">
            <i class="bi bi-file-earmark-text" style="font-size:3rem"></i>
            <h2 class="mt-2">@Model.ContractCount</h2><p class="text-muted mb-0">合同总数</p>
        </div></div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-info text-info h-100"><div class="card-body text-center">
            <i class="bi bi-currency-dollar" style="font-size:3rem"></i>
            <h2 class="mt-2">¥@Model.TotalAmount.ToString("N0")</h2>
            <p class="text-muted mb-0">合同总金额（@Model.InProgressCount 个执行中）</p>
        </div></div>
    </div>
</div>

<div class="row g-4 mt-2">
    <div class="col-lg-4">
        <a href="/Customers" class="text-decoration-none"><div class="card bg-primary bg-opacity-10 border-primary h-100 hover-shadow">
            <div class="card-body text-center p-4"><i class="bi bi-building text-primary" style="font-size:2rem"></i>
                <h5 class="mt-2 text-dark">客户管理</h5><small class="text-muted">管理企业客户信息</small></div>
        </div></a>
    </div>
    <div class="col-lg-4">
        <a href="/Contacts" class="text-decoration-none"><div class="card bg-success bg-opacity-10 border-success h-100">
            <div class="card-body text-center p-4"><i class="bi bi-person-lines-fill text-success" style="font-size:2rem"></i>
                <h5 class="mt-2 text-dark">联系人管理</h5><small class="text-muted">管理客户联系人</small></div>
        </div></a>
    </div>
    <div class="col-lg-4">
        <a href="/Contracts" class="text-decoration-none"><div class="card bg-warning bg-opacity-10 border-warning h-100">
            <div class="card-body text-center p-4"><i class="bi bi-file-earmark-text text-warning" style="font-size:2rem"></i>
                <h5 class="mt-2 text-dark">合同管理</h5><small class="text-muted">管理合同与回款</small></div>
        </div></a>
    </div>
</div>
