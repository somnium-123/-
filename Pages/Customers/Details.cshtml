@page "{id:int}"
@model CrmLite.Pages.Customers.DetailsModel
@{ ViewData["Title"] = $"客户详情 — {Model.Customer.Name}"; }

<nav aria-label="breadcrumb"><ol class="breadcrumb">
    <li class="breadcrumb-item"><a asp-page="Index">客户管理</a></li>
    <li class="breadcrumb-item active">@Model.Customer.Name</li>
</ol></nav>

<div class="d-flex justify-content-between align-items-start mb-3">
    <h4>@Model.Customer.Name</h4>
    <div>
        <a asp-page="Edit" asp-route-id="@Model.Customer.CustomerId" class="btn btn-warning btn-sm"><i class="bi bi-pencil"></i> 编辑</a>
        <a asp-page="Index" class="btn btn-secondary btn-sm">返回</a>
    </div>
</div>

<div class="row"><div class="col-lg-8">
<div class="card mb-3"><div class="card-header"><strong>客户信息</strong></div>
<div class="card-body"><div class="row">
    <div class="col-md-6"><dl>
        <dt>客户编号</dt><dd><code>@Model.Customer.Code</code></dd>
        <dt>所属行业</dt><dd>@(Model.Customer.Industry ?? "-")</dd>
        <dt>企业规模</dt><dd>@(Model.Customer.Scale ?? "-")</dd>
        <dt>客户级别</dt><dd>@(Model.Customer.Level switch {
            CrmLite.Models.CustomerLevel.VIP => "VIP",
            CrmLite.Models.CustomerLevel.Important => "重要",
            _ => "普通"})</dd>
        <dt>所在地区</dt><dd>@(Model.Customer.Region ?? "-")</dd>
    </dl></div>
    <div class="col-md-6"><dl>
        <dt>联系电话</dt><dd>@(Model.Customer.Phone ?? "-")</dd>
        <dt>企业网址</dt><dd>@(Model.Customer.Website ?? "-")</dd>
        <dt>详细地址</dt><dd>@(Model.Customer.Address ?? "-")</dd>
        <dt>邮政编码</dt><dd>@(Model.Customer.PostalCode ?? "-")</dd>
        <dt>创建时间</dt><dd>@Model.Customer.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
    </dl></div>
    @if (!string.IsNullOrEmpty(Model.Customer.Remark))
    {<div class="col-12"><dt>备注</dt><dd>@Model.Customer.Remark</dd></div>}
</div></div></div>

<div class="card mb-3"><div class="card-header d-flex justify-content-between align-items-center">
    <strong>关联联系人 (@Model.Customer.Contacts.Count)</strong>
    <a asp-page="/Contacts/Create" asp-route-customerId="@Model.Customer.CustomerId" class="btn btn-sm btn-primary">新增联系人</a>
</div>
<div class="card-body">
    @if (!Model.Customer.Contacts.Any())
    {<p class="text-muted">暂无联系人</p>}
    else
    {<table class="table table-sm table-hover"><thead><tr><th>姓名</th><th>职务</th><th>电话</th><th>邮箱</th><th>主要</th></tr></thead><tbody>
    @foreach (var ct in Model.Customer.Contacts)
    {<tr><td>@ct.Name</td><td>@(ct.Position ?? "-")</td><td>@(ct.Phone ?? "-")</td>
        <td>@(ct.Email ?? "-")</td><td>@(ct.IsPrimary ? "✓" : "")</td></tr>}
    </tbody></table>}
</div></div>

<div class="card"><div class="card-header"><strong>关联合同 (@Model.Customer.Contracts.Count)</strong></div>
<div class="card-body">
    @if (!Model.Customer.Contracts.Any())
    {<p class="text-muted">暂无合同</p>}
    else
    {<table class="table table-sm table-hover"><thead><tr><th>合同编号</th><th>合同名称</th><th>金额</th><th>状态</th><th>签订日期</th></tr></thead><tbody>
    @foreach (var ctr in Model.Customer.Contracts)
    {<tr><td><code>@ctr.ContractCode</code></td><td>@ctr.Name</td>
        <td>¥@ctr.Amount.ToString("N2")</td>
        <td>@(ctr.Status == CrmLite.Models.ContractStatus.InProgress ? "执行中" : ctr.Status == CrmLite.Models.ContractStatus.Completed ? "已完成" : "已终止")</td>
        <td>@ctr.SignedDate.ToString("yyyy-MM-dd")</td></tr>}
    </tbody></table>}
</div></div>

</div></div>
