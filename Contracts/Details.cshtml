@page "{id:int}"
@model CrmLite.Pages.Contracts.DetailsModel
@{ ViewData["Title"] = $"合同详情 — {Model.Contract.Name}"; }

<nav aria-label="breadcrumb"><ol class="breadcrumb">
    <li class="breadcrumb-item"><a asp-page="Index">合同管理</a></li>
    <li class="breadcrumb-item active">@Model.Contract.Name</li>
</ol></nav>

<div class="d-flex justify-content-between align-items-start mb-3">
    <h4>@Model.Contract.Name</h4>
    <div>
        <a asp-page="Edit" asp-route-id="@Model.Contract.ContractId" class="btn btn-warning"><i class="bi bi-pencil"></i> 编辑</a>
        <a asp-page="Index" class="btn btn-secondary">返回</a>
    </div>
</div>

<div class="row"><div class="col-lg-6">
    <div class="card mb-3"><div class="card-header"><strong>合同信息</strong></div>
        <div class="card-body"><dl class="row mb-0">
            <dt class="col-sm-4">合同编号</dt><dd class="col-sm-8"><code>@Model.Contract.ContractCode</code></dd>
            <dt class="col-sm-4">合同状态</dt><dd class="col-sm-8">
                @if (Model.Contract.Status == CrmLite.Models.ContractStatus.InProgress)
                {<span class="badge bg-primary">执行中</span>}
            else if (Model.Contract.Status == CrmLite.Models.ContractStatus.Completed)
            {<span class="badge bg-success">已完成</span>}
            else
            {<span class="badge bg-secondary">已终止</span>}</dd>
            <dt class="col-sm-4">合同金额</dt><dd class="col-sm-8"><strong>¥@Model.Contract.Amount.ToString("N2")</strong></dd>
            <dt class="col-sm-4">签订日期</dt><dd class="col-sm-8">@Model.Contract.SignedDate.ToString("yyyy-MM-dd")</dd>
            <dt class="col-sm-4">预计回款</dt><dd class="col-sm-8">@(Model.Contract.ExpectedPaymentDate?.ToString("yyyy-MM-dd") ?? "未设置")</dd>
            @if (!string.IsNullOrEmpty(Model.Contract.Remark))
            {<dt class="col-sm-4">备注</dt><dd class="col-sm-8">@Model.Contract.Remark</dd>}
        </dl></div>
    </div>
</div>

<div class="col-lg-6">
    <div class="card mb-3"><div class="card-header"><strong>关联客户</strong></div>
        <div class="card-body">
            @if (Model.Contract.Customer != null)
            {<dl class="row mb-0"><dt class="col-sm-4">客户名称</dt><dd class="col-sm-8"><a asp-page="/Customers/Details" asp-route-id="@Model.Contract.Customer.CustomerId">@Model.Contract.Customer.Name</a></dd>
                <dt class="col-sm-4">行业</dt><dd class="col-sm-8">@(Model.Contract.Customer.Industry ?? "-")</dd>
                <dt class="col-sm-4">级别</dt><dd class="col-sm-8">@(Model.Contract.Customer.Level switch { CrmLite.Models.CustomerLevel.VIP => "VIP", CrmLite.Models.CustomerLevel.Important => "重要", _ => "普通" })</dd>
            </dl>}
            else
            {<p class="text-muted">未知客户</p>}
        </div>
    </div>

    <div class="card"><div class="card-header"><strong>关联联系人</strong></div>
        <div class="card-body">
            @if (Model.Contract.Contact != null)
            {<dl class="row mb-0"><dt class="col-sm-4">姓名</dt><dd class="col-sm-8">@Model.Contract.Contact.Name</dd>
                <dt class="col-sm-4">职务</dt><dd class="col-sm-8">@(Model.Contract.Contact.Position ?? "-")</dd>
                <dt class="col-sm-4">电话</dt><dd class="col-sm-8">@(Model.Contract.Contact.Phone ?? "-")</dd>
                <dt class="col-sm-4">邮箱</dt><dd class="col-sm-8">@(Model.Contract.Contact.Email ?? "-")</dd>
            </dl>}
            else
            {<p class="text-muted">未关联联系人</p>}
        </div>
    </div>
</div></div>
