@page
@model CrmLite.Pages.Contracts.IndexModel
@{ ViewData["Title"] = "合同管理"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3><i class="bi bi-file-earmark-text"></i> 合同管理</h3>
    <a asp-page="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> 新增合同</a>
</div>

@if (TempData["Success"] != null)
{<div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>}

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <select asp-for="FilterStatus" class="form-select" onchange="this.form.submit()">
            <option value="">全部状态</option>
            <option value="0">执行中</option><option value="1">已完成</option><option value="2">已终止</option>
        </select>
    </div>
    <div class="col-auto">
        <a asp-page="Index" class="btn btn-outline-secondary">重置</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark"><tr>
            <th>合同编号</th><th>合同名称</th><th>关联客户</th><th>关联联系人</th><th>金额</th><th>签订日期</th><th>回款日期</th><th>状态</th><th style="width:180px">操作</th>
        </tr></thead>
        <tbody>
            @if (!Model.Contracts.Any())
            {<tr><td colspan="9" class="text-center text-muted py-4">暂无合同数据</td></tr>}
            @foreach (var c in Model.Contracts)
            {
                <tr>
                    <td><code>@c.ContractCode</code></td>
                    <td><strong>@c.Name</strong></td>
                    <td>@c.Customer?.Name</td>
                    <td>@(c.Contact?.Name ?? "-")</td>
                    <td class="text-end">¥@c.Amount.ToString("N2")</td>
                    <td>@c.SignedDate.ToString("yyyy-MM-dd")</td>
                    <td>@(c.ExpectedPaymentDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                    <td>
                        @if (c.Status == CrmLite.Models.ContractStatus.InProgress)
                        {<span class="badge bg-primary">执行中</span>}
                    else if (c.Status == CrmLite.Models.ContractStatus.Completed)
                    {<span class="badge bg-success">已完成</span>}
                    else
                    {<span class="badge bg-secondary">已终止</span>}
                    </td>
                    <td>
                        <a asp-page="Details" asp-route-id="@c.ContractId" class="btn btn-sm btn-info text-white"><i class="bi bi-eye"></i></a>
                        <a asp-page="Edit" asp-route-id="@c.ContractId" class="btn btn-sm btn-warning"><i class="bi bi-pencil"></i></a>
                        <a asp-page="Delete" asp-route-id="@c.ContractId" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{<nav><ul class="pagination justify-content-center">
    @for (int i = 1; i <= Model.TotalPages; i++)
    {<li class="page-item @(i == Model.CurrentPage ? "active" : "")">
        <a class="page-link" asp-page="Index" asp-route-pageIndex="@i" asp-route-FilterStatus="@Model.FilterStatus">@i</a></li>}
</ul></nav>}
